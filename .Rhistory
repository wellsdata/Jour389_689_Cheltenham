# install.packages("htmlwidgets")
# install.packages("leaflet")
#install.packages("sf")
#install.packages('DT')
library(DT)
library(tidyverse)
library(rio)
library(janitor)
library(htmlwidgets)
library(leaflet)
library(sf)
library(googlesheets4)
library(formattable)
gs4_deauth()
death_certs <- read_sheet("https://docs.google.com/spreadsheets/d/1Qu7FSUzCAeU4gdZ9BpIvfxI5kBp5rAOgEiaQ2h0ff4k/edit?gid=0#gid=0") |>
clean_names()
chelt_deaths <- read_sheet("https://docs.google.com/spreadsheets/d/1qy17Gwxyb-W6P2tDqaI6jUymK4n7cmnFToNIkJ5GCI4/edit?usp=sharing", sheet="chelt_deaths") |>
clean_names() |>
mutate(across(
# Select all the list columns
c(number_of_inmates, total_deaths, total_escapes, total_hired_out, total_sent_to_hospital),
~ .x |>
as.character() |>              # Pull it out of the 'list' box into a string
str_remove_all("\\*") |>       # Remove those asterisks (e.g., "56*" becomes "56")
na_if("NA") |>                 # Convert the string "NA" to a real R NA
na_if("na") |>                 # Handle lowercase "na"
na_if("N/A") |>                # Handle "N/A"
as.numeric()                   # Finally, turn it into a number
)) |>
slice(-43)
hickey_deaths <- read_sheet("https://docs.google.com/spreadsheets/d/1FnXL2BiktaoEQDh-TAzgdTDuucJfaENKQ1wVZaItdww/edit?usp=sharing") |>
clean_names() |>
mutate(across(
# Select all the list columns
c(year_of_report,number_of_inmates, total_deaths, total_escapes, total_hired_out, total_sent_to_hospital),
~ .x |>
as.character() |>              # Pull it out of the 'list' box into a string
str_remove_all("\\*") |>       # Remove those asterisks (e.g., "56*" becomes "56")
na_if("NA") |>                 # Convert the string "NA" to a real R NA
na_if("na") |>                 # Handle lowercase "na"
na_if("N/A") |>                # Handle "N/A"
as.numeric()                   # Finally, turn it into a number
))
# --- Config ---
biennial_years <- c(1903, 1907, 1909, 1911, 1913, 1915, 1917, 1930, 1932, 1934, 1936, 1938)
biennial_prev_years <- biennial_years - 1
# --- Step 1: Death cert counts per year (Cheltenham only) ---
cert_counts <- death_certs |>
filter(facility == "cheltenham") |>
count(death_year, name = "death_cert")
# --- Step 2: Join annual report deaths to cert counts ---
joined <- chelt_deaths |>
filter(!is.na(year_of_report)) |>
select(year_of_report, total_deaths) |>
full_join(cert_counts, by = c("year_of_report" = "death_year")) |>
arrange(year_of_report)
# --- Step 3: For biennial years, add the previous year's certs ---
prev_year_certs <- joined |>
filter(year_of_report %in% biennial_prev_years) |>
transmute(
biennial_year  = year_of_report + 1,
cert_prev_year = death_cert
)
# --- Step 4: Calculate best estimate per row ---
deaths_summary <- joined |>
mutate(
is_biennial  = year_of_report %in% biennial_years,
is_prev_year = year_of_report %in% biennial_prev_years
) |>
filter(!is_prev_year) |>  # drop years already absorbed into biennial totals
left_join(prev_year_certs, by = c("year_of_report" = "biennial_year")) |>
mutate(
# Combine two years of certs for biennial rows
cert_total = case_when(
is_biennial & !(is.na(death_cert) & is.na(cert_prev_year)) ~
coalesce(death_cert, 0) + coalesce(cert_prev_year, 0),
is_biennial ~ NA_real_,
TRUE ~ death_cert
),
# Best estimate: whichever source is larger
best_estimate = case_when(
!is.na(total_deaths) & !is.na(cert_total) ~ pmax(total_deaths, cert_total),
!is.na(total_deaths)                       ~ total_deaths,
!is.na(cert_total)                         ~ cert_total,
TRUE                                        ~ NA_real_
)
# --- Step 5: Total ---
cat("Total deaths:", sum(deaths_summary$best_estimate, na.rm = TRUE), "\n")
cat("Rows with no data:", sum(is.na(deaths_summary$best_estimate)), "\n")
View(deaths_summary)
View(cert_counts)
View(joined)
View(prev_year_certs)
View(deaths_summary)
write.csv(deaths_summary, "deaths_summary.csv", row.names = FALSE)
View(hickey_deaths)
hickey_deaths <- hickey_deaths %>%
slice(-51)
View(hickey_deaths)
hickey_deaths <- hickey_deaths %>%
slice(-51,50,49)
hickey_deaths <- hickey_deaths %>%
slice(-50,-49)
View(hickey_deaths)
hickey_deaths <- hickey_deaths %>%
slice(-50,-49)
hickey_deaths_new <- hickey_deaths %>%
select(year_of_report,total_deaths)
View(hickey_deaths_new)
View(deaths_summary)
chelt_hickey <- hickey_deaths_new |>
full_join(deaths_summary, by = "year_of_report")
View(chelt_hickey)
chelt_hickey <- chelt_hickey %>%
select(year_of_report,total_deaths.x,best_estimate)
View(chelt_hickey)
chelt_hickey <- chelt_hickey |>
rename(hickey_deaths = total_deaths.x,
chelt_deaths = best_estimate)
View(chelt_hickey)
write.csv(deaths_summary, "chelt_hickey.csv", row.names = FALSE)
write.csv(deaths_summary, "chelt_hickey_new.csv", row.names = FALSE)
chelt_hickey_new <- chelt_hickey |>
rename(hickey_deaths = total_deaths.x,
chelt_deaths = best_estimate)
View(chelt_hickey)
write.csv(deaths_summary, "chelt_hickey.csv", row.names = FALSE)
chelt_hickey_n <- hickey_deaths_new |>
full_join(deaths_summary, by = "year_of_report")
chelt_hickey <- chelt_hickey %>%
select(year_of_report,total_deaths.x,best_estimate)
View(chelt_hickey_n)
chelt_hickey_n <- chelt_hickey_n %>%
select(year_of_report,total_deaths.x,best_estimate)
write_csv(chelt_hickey_n, "chelt_hickey_n.csv",row.names = FALSE)
write.csv(chelt_hickey_n, "chelt_hickey_n.csv", row.names = FALSE)
